{
  "name": "asociatia-idei-monorepo",
  "version": "1.0.0",
  "description": "Mono-repo for Asociatia IDEI website, e-learning platform, and shared components",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "website:dev": "npm run dev --workspace=apps/website",
    "website:build": "npm run build --workspace=apps/website",
    "shared-ui:build": "npm run build --workspace=packages/shared-ui"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "monorepo",
    "nextjs",
    "openedx",
    "builder.io",
    "asociatia-idei"
  ]
}
